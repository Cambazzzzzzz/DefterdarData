{
  "name": "defterdar-muhasebe",
  "version": "2.3.0",
  "description": "DefterdarMuhasebe - Profesyonel STK Muhasebe Sistemi",
  "main": "electron.js",
  "author": "CMS Team <info@cmsteam.com>",
  "homepage": "https://cmsteam.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64",
    "build-dir": "electron-builder --win --x64 --dir",
    "dist": "npm run build",
    "railway": "node server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.6.0",
    "cloudinary": "^2.9.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cmsteam.defterdarmuhasebe",
    "productName": "DefterdarMuhasebe",
    "copyright": "Copyright © 2025 CMS Team. Tüm hakları saklıdır.",
    "forceCodeSigning": false,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "compression": "maximum",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "CMS Team",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false,
      "signDlls": false,
      "legalTrademarks": "CMS Team"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DefterdarMuhasebe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "uninstallDisplayName": "DefterdarMuhasebe",
      "displayLanguageSelector": false,
      "installerLanguages": [
        "tr_TR"
      ],
      "language": "1055",
      "multiLanguageInstaller": false,
      "packElevateHelper": false,
      "preCompressedFileExtensions": [
        ".br",
        ".gz",
        ".7z",
        ".rar",
        ".zip"
      ],
      "differentialPackage": false,
      "include": "build/installer.nsh",
      "warningsAsErrors": false,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "guid": "12345678-1234-1234-1234-123456789012"
    },
    "files": [
      "**/*",
      "!data/**",
      "!dist/**",
      "!node_modules/.cache/**",
      "!*.md"
    ],
    "extraMetadata": {
      "author": "CMS Team"
    }
  }
}
